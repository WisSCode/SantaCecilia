<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="frontend.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F5EF">

    <Grid ColumnDefinitions="260,*">

        <!-- SIDEBAR -->
        <StackLayout Grid.Column="0" BackgroundColor="White">

            <!-- Logo -->
            <StackLayout Padding="20" Orientation="Horizontal" Spacing="12">
                <Image Source="logo_santa_cecilia.png" HeightRequest="40" WidthRequest="40"/>    
                <StackLayout>
                    <Label Text="Santa Cecilia"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="#1F2937"/>
                    <Label Text="Gestión de Nómina"
                           FontSize="12"
                           TextColor="#6B7280"/>
                </StackLayout>
            </StackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>

            <!-- Menu -->
            <VerticalStackLayout Padding="12" Spacing="6">

                <Button Text="Inicio"
                        BackgroundColor="#9DCBB3"
                        TextColor="White"
                        CornerRadius="6"/>

                <Button Text="Registro Diario"
                        BackgroundColor="Transparent"
                        TextColor="#374151"/>

                <Button Text="Trabajadores"
                        BackgroundColor="Transparent"
                        TextColor="#374151"/>

                <Button Text="Nómina"
                        BackgroundColor="Transparent"
                        TextColor="#374151"/>

                <Button Text="Reportes"
                        BackgroundColor="Transparent"
                        TextColor="#374151"/>

            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>

            <!-- Perfil -->
            <StackLayout Padding="16">
                <Label Text="Administrador"
                       FontAttributes="Bold"
                       FontSize="13"/>
                <Label Text="Ver perfil"
                       FontSize="12"
                       TextColor="#6B7280"/>
            </StackLayout>

        </StackLayout>

        <!-- CONTENIDO -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="24" Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackLayout>
                        <Label Text="Panel de Control"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1F2937"/>
                        <Label Text="miércoles, 4 de febrero de 2026"
                               FontSize="12"
                               TextColor="#6B7280"/>
                    </StackLayout>

                    <Button Grid.Column="1"
                            Text="Cerrar Sesión"
                            TextColor="#DC2626"
                            BackgroundColor="Transparent"/>
                </Grid>

                <!-- ALERTAS -->
                <Frame BackgroundColor="#FFF7ED" BorderColor="#FDBA74">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠️"
                               FontSize="18"/>
                        <Label Text="Faltan 2 días para el cierre de nómina semanal"
                               FontAttributes="Bold"
                               TextColor="#9A3412"/>
                    </HorizontalStackLayout>
                </Frame>

                <Frame BackgroundColor="#EFF6FF" BorderColor="#93C5FD">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="ℹ️"
                               FontSize="18"/>
                        <Label Text="3 trabajadores pendientes de validación"
                               FontAttributes="Bold"
                               TextColor="#1E3A8A"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- CARDS -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">

                    <!-- Card -->
                    <Frame Grid.Column="0" BorderColor="#E5E7EB">
                        <VerticalStackLayout>
                            <Label Text="Trabajadores Activos"
                                   FontSize="12"
                                   TextColor="#6B7280"/>
                            <Label Text="45"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                            <Label Text="esta semana"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" BorderColor="#E5E7EB">
                        <VerticalStackLayout>
                            <Label Text="Horas Trabajadas"
                                   FontSize="12"
                                   TextColor="#6B7280"/>
                            <Label Text="1,856"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                            <Label Text="promedio diario"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="2" BorderColor="#E5E7EB">
                        <VerticalStackLayout>
                            <Label Text="Nómina Semanal"
                                   FontSize="12"
                                   TextColor="#6B7280"/>
                            <Label Text="B/.12,450"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                            <Label Text="3:00 PM"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="3" BorderColor="#E5E7EB">
                        <VerticalStackLayout>
                            <Label Text="Actividades"
                                   FontSize="12"
                                   TextColor="#6B7280"/>
                            <Label Text="156"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                            <Label Text="vs semana anterior"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- ACTIVIDADES -->
                <Frame BorderColor="#E5E7EB">
                    <VerticalStackLayout>

                        <Label Text="Actividades Recientes"
                               FontAttributes="Bold"
                               FontSize="16"/>

                        <CollectionView ItemsSource="{Binding Actividades}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,3*,*,*,*,*"
                                          Padding="8">

                                        <Label Text="{Binding Worker}" Grid.Column="0"/>
                                        <Label Text="{Binding Activity}" Grid.Column="1"/>
                                        <Label Text="{Binding Lote}" Grid.Column="2"/>
                                        <Label Text="{Binding Rate}" Grid.Column="3"/>
                                        <Label Text="{Binding Hours}" Grid.Column="4"/>
                                        <Label Text="{Binding Date}" Grid.Column="5"/>

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
