<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.WorkTypesPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">
                
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12"
                    VerticalOptions="Center"
                    Padding="0">

                    <!-- Text -->
                    <VerticalStackLayout Spacing="2"
                                        VerticalOptions="Center"
                                        Grid.Column="0">

                        <Label Text="Tipos de Trabajo"
                            FontSize="{OnIdiom Phone=18, Desktop=20}"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Catalogo de actividades y tarifas"
                            FontSize="{OnIdiom Phone=10, Desktop=11}"
                            TextColor="{StaticResource TextSecondary}"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Button -->
                    <Button Grid.Column="1"
                            Text="+ Agregar"
                            Clicked="OnAddClicked"
                            BackgroundColor="#9EC9B4"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            HeightRequest="{OnIdiom Phone=36, Desktop=40}"
                            Padding="{OnIdiom Phone='12,0', Desktop='16,0'}"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                </Grid>

                <!-- Summary Stats -->
                    <Grid ColumnDefinitions="{OnIdiom Phone='*,*', Desktop='*,*'}"
                        RowDefinitions="Auto"
                        ColumnSpacing="{OnIdiom Phone=8, Desktop=12}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalTypesLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Tipos Activos" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                        <Border Grid.Column="1"
                            Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="AvgRateLabel" Text="B/.0.00" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Tarifa Promedio" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tabla de actividades (con buscador y lista) -->
                <Border Stroke="Transparent"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="0">
                        <!-- Header -->
                        <Grid BackgroundColor="#9EC9B4" Padding="16,12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Catálogo de Actividades"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Catálogo de actividades y tarifas"
                                       FontSize="11"
                                       TextColor="#E8F5EE" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Buscador -->
                        <Border Stroke="#EEEBE5"
                                StrokeThickness="0,0,0,1"
                                Padding="12,8"
                                BackgroundColor="White">
                            <Entry x:Name="SearchEntry"
                                   Placeholder="Buscar actividad..."
                                   FontSize="12"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource TextPrimary}"
                                   TextChanged="OnSearchChanged" />
                        </Border>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="0">
                                <!-- Cabecera de tabla -->
                                <Grid Padding="16,10"
                                      ColumnDefinitions="{OnIdiom Phone='180,100,80', Desktop='3*,2*,2*'}"
                                      ColumnSpacing="6"
                                      BackgroundColor="#FAFAF7">
                                    <Label x:Name="HeaderName" 
                                           Text="NOMBRE ↑" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Start" 
                                           TextColor="{StaticResource TextSecondary}" >
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByName" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="HeaderRate" 
                                           Grid.Column="1" 
                                           Text="TARIFA" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Start" 
                                           TextColor="{StaticResource TextSecondary}" >
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByRate" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Grid.Column="2" 
                                           Text="ACCIONES" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="End" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </Grid>

                                <!-- Items -->
                                <CollectionView x:Name="WorkTypesList" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="#EEEBE5" StrokeThickness="0,0,0,1" Padding="16,10" BackgroundColor="White">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='180,100,80', Desktop='3*,2*,2*'}" ColumnSpacing="6">
                                                    <!-- NOMBRE -->
                                                    <Label Text="{Binding Name}" 
                                                           FontAttributes="Bold" 
                                                           FontSize="12" 
                                                           TextColor="{StaticResource TextPrimary}" 
                                                           VerticalOptions="Center" 
                                                           HorizontalTextAlignment="Start" />
                                                    <!-- TARIFA -->
                                                    <Label Grid.Column="1" 
                                                           Text="{Binding DefaultRate, StringFormat='B/.{0:F4}/hr'}" 
                                                           FontSize="11" 
                                                           TextColor="{StaticResource TextSecondary}" 
                                                           VerticalOptions="Center" 
                                                           HorizontalTextAlignment="Start" />
                                                    <!-- ACCIONES -->
                                                    <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center" HorizontalOptions="End">
                                                        <Label Text="Editar"
                                                               FontSize="11"
                                                               TextColor="#2E7D5B">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Tapped="OnEditTapped"
                                                                    CommandParameter="{Binding .}" />
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                        <Label Text="Eliminar"
                                                               FontSize="11"
                                                               TextColor="#E07A5F">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Tapped="OnDeleteTapped"
                                                                    CommandParameter="{Binding .}" />
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </HorizontalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>