<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.WorkTypesPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">
                
                <!-- Header -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Tipos de Trabajo" Style="{StaticResource Heading2}" />
                    <Label Text="Catalogo de actividades y tarifas" Style="{StaticResource BodySecondary}" />
                </VerticalStackLayout>

                <!-- Summary Stats -->
                <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                      RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                      ColumnSpacing="12"
                      RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalTypesLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Tipos Activos" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                            Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="AvgRateLabel" Text="B/.0.00" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Tarifa Promedio" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Actions -->
                <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,Auto'}"
                      RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                      ColumnSpacing="10"
                      RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="10">
                        <Entry x:Name="SearchEntry" Placeholder="Buscar actividad..." TextChanged="OnSearchChanged" />
                    </Border>
                    <Button Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                            Text="+ Agregar"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalOptions="{OnIdiom Phone=Start, Desktop=End}"
                            Clicked="OnAddClicked" />
                </Grid>

                <!-- Work Types List -->
                <Border Style="{StaticResource CardFrame}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Catalogo de Actividades" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="0">
                                <!-- Cabecera de tabla -->
                                <Grid Padding="10"
                                      ColumnDefinitions="{OnIdiom Phone='190,120,200', Desktop='3*,3*,Auto'}"
                                      BackgroundColor="{StaticResource SurfaceSecondary}"
                                      ColumnSpacing="8">
                                    <Label x:Name="HeaderName" 
                                           Text="NOMBRE &#x2191;" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Start" 
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label x:Name="HeaderRate" 
                                           Grid.Column="1" 
                                           Text="TARIFA" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Start" 
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="2" 
                                           Text="ACCIONES" 
                                           FontSize="10" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Start" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </Grid>

                                <!-- Items -->
                                <CollectionView x:Name="WorkTypesList" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Border}" StrokeThickness="1" Padding="10" Margin="0">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='190,120,200', Desktop='3*,2.8*,Auto'}" ColumnSpacing="8">
                                                    <!-- NOMBRE -->
                                                    <Label Text="{Binding Name}" 
                                                           FontAttributes="Bold" 
                                                           FontSize="12" 
                                                           TextColor="{StaticResource TextPrimary}" 
                                                           VerticalOptions="Center" 
                                                           HorizontalTextAlignment="Start" />
                                                    <!-- TARIFA -->
                                                    <Label Grid.Column="1" 
                                                           Text="{Binding DefaultRate, StringFormat='B/.{0:F4}/hr'}" 
                                                           FontSize="11" 
                                                           TextColor="{StaticResource TextSecondary}" 
                                                           VerticalOptions="Center" 
                                                           HorizontalTextAlignment="Start" />
                                                    <!-- ACCIONES -->
                                                    <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                                        <Button Text="Editar" 
                                                                Clicked="OnEditClicked"
                                                                CommandParameter="{Binding .}"
                                                                Style="{StaticResource OutlineButton}"
                                                                FontSize="11"
                                                                Padding="10,6"
                                                                MinimumHeightRequest="32" />
                                                        <Button Text="Eliminar" 
                                                                Clicked="OnDeleteClicked"
                                                                CommandParameter="{Binding .}"
                                                                BackgroundColor="Transparent"
                                                                TextColor="#E07A5F"
                                                                BorderColor="#E07A5F"
                                                                BorderWidth="1"
                                                                FontSize="11"
                                                                Padding="10,6"
                                                                MinimumHeightRequest="32" />
                                                    </HorizontalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>