<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="frontend.Pages.WorkersHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F5EF">

    <ScrollView>
              <VerticalStackLayout Padding="{OnIdiom Phone='16,14', Desktop='24'}"
                                                  Spacing="{OnIdiom Phone=16, Desktop=20}">

            <!-- HEADER -->
              <Grid BackgroundColor="#9EC9B4"
                     Padding="{OnIdiom Phone=16, Desktop=20}"
                  ColumnDefinitions="Auto,*,Auto">

                <Frame WidthRequest="42"
                       HeightRequest="42"
                       CornerRadius="0"
                       BackgroundColor="White"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <Label x:Name="AvatarLabel"
                           Text="-"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           TextColor="#2E3A34"/>
                </Frame>

                <VerticalStackLayout Grid.Column="1" Padding="12,0">
                    <Label x:Name="WorkerNameLabel"
                           Text="Cargando..."
                           FontAttributes="Bold"
                           FontSize="{OnIdiom Phone=14, Desktop=16}"
                           TextColor="White"/>
                    <Label x:Name="WorkerCodeLabel"
                           Text=""
                           FontSize="{OnIdiom Phone=11, Desktop=12}"
                           TextColor="#F2F7F4"/>
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Text="Cerrar Sesión"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="{OnIdiom Phone=11, Desktop=12}"
                        Padding="{OnIdiom Phone='8,4', Desktop='12,6'}"
                        Clicked="OnLogoutClicked"/>
            </Grid>

            <!-- HORAS DE ESTA SEMANA -->
            <Frame BackgroundColor="White"
                   BorderColor="#D6DAD7"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Horas de esta semana"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#2E3A34"/>
                    <Label x:Name="WeeklyHoursLabel"
                           Text="0h"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#2E3A34"/>
                </VerticalStackLayout>
            </Frame>

            <!-- PAGO NETO -->
            <Frame BackgroundColor="#9EC9B4"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Pago Neto Estimado"
                           FontSize="14"
                           TextColor="White"/>
                    <Label x:Name="NetPayLabel"
                           Text="B/.0.00"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <!-- DESGLOSE -->
            <Frame BorderColor="#D6DAD7"
                   BackgroundColor="White"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">

                <VerticalStackLayout Spacing="10">

                    <Label Text="Desglose de Pago Semanal"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#2E3A34"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Devengado Bruto:"
                               TextColor="#2E3A34"/>
                        <Label x:Name="GrossAmountLabel"
                               Grid.Column="1"
                               Text="B/.0.00"
                               HorizontalTextAlignment="End"
                               TextColor="#2E3A34"/>
                    </Grid>

                    <Frame BackgroundColor="#FFF5F5"
                           BorderColor="#FCA5A5"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="DESCUENTOS:"
                                   FontAttributes="Bold"
                                   TextColor="#DC2626"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Social (9%)"
                                       TextColor="#2E3A34"/>
                                <Label x:Name="SsDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Educativo (1.25%)"
                                       TextColor="#2E3A34"/>
                                <Label x:Name="SeDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Sindicato"
                                       TextColor="#2E3A34"/>
                                <Label x:Name="UnionDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.1.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#9EC9B4"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="TOTAL A RECIBIR:"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label x:Name="TotalNetLabel"
                                   Grid.Column="1"
                                   Text="B/.0.00"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="End"
                                   TextColor="White"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- ACTIVIDADES RECIENTES -->
            <Frame BorderColor="#D6DAD7"
                   BackgroundColor="White"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Actividades Recientes"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#2E3A34"/>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <VerticalStackLayout Spacing="8">
                            <!-- HEADER TABLA -->
                            <Grid ColumnDefinitions="{OnIdiom Phone='70,3*,90,70,90,90', Desktop='70,3*,90,70,90,90'}"
                                  Padding="0,0,0,4">

                                <Label Text="FECHA"
                                       FontSize="11"
                                       TextColor="#6B7280"/>

                                <Label Grid.Column="1"
                                       Text="ACTIVIDAD"
                                       FontSize="11"
                                       TextColor="#6B7280"/>

                                <Label Grid.Column="2"
                                       Text="LOTE"
                                       FontSize="11"
                                       TextColor="#6B7280"/>

                                <Label Grid.Column="3"
                                       Text="HORAS"
                                       FontSize="11"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>

                                <Label Grid.Column="4"
                                       Text="TARIFA"
                                       FontSize="11"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>

                                <Label Grid.Column="5"
                                       Text="MONTO"
                                       FontSize="11"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>
                            </Grid>

                            <CollectionView x:Name="ActivitiesCollection">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="{OnIdiom Phone='70,3*,90,70,90,90', Desktop='70,3*,90,70,90,90'}"
                                              Padding="0,6">

                                            <Label Text="{Binding Fecha}"
                                                   TextColor="#9CA3AF"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Actividad}"
                                                   FontAttributes="Bold"
                                                   TextColor="#2E3A34"/>

                                            <Label Grid.Column="2"
                                                   Text="{Binding Lote}"
                                                   TextColor="#6B7280"/>

                                            <Label Grid.Column="3"
                                                   Text="{Binding Horas}"
                                                   HorizontalTextAlignment="End"
                                                   TextColor="#2E3A34"/>

                                            <Label Grid.Column="4"
                                                   Text="{Binding Tarifa}"
                                                   HorizontalTextAlignment="End"
                                                   TextColor="#9EC9B4"/>

                                            <Label Grid.Column="5"
                                                   Text="{Binding Monto}"
                                                   HorizontalTextAlignment="End"
                                                   TextColor="#9EC9B4"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
