<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="frontend.Pages.WorkersHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F5EF">

    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone='16,14', Desktop='24'}"
                             Spacing="{OnIdiom Phone=16, Desktop=20}">

            <!-- HEADER -->
            <Grid BackgroundColor="#9EC9B4"
                  Padding="{OnIdiom Phone=16, Desktop=20}"
                  ColumnDefinitions="{OnIdiom Phone='Auto,*', Desktop='Auto,*,Auto'}"
                  RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                  RowSpacing="{OnIdiom Phone=8, Desktop=0}">

                <!-- Avatar con iniciales -->
                <Border WidthRequest="42"
                        HeightRequest="42"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        HorizontalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <Label x:Name="AvatarLabel"
                           Text="LF"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="#2E7D5B"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Padding="12,0" VerticalOptions="Center">
                    <Label x:Name="WorkerNameLabel"
                           Text="Luis Fernandez"
                           FontAttributes="Bold"
                           FontSize="{OnIdiom Phone=14, Desktop=16}"
                           TextColor="White"/>
                    <Label x:Name="WorkerCedulaLabel"
                           Text="Cédula: —"
                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                           TextColor="#E8F5EE"/>
                    <Label x:Name="WorkerCodeLabel"
                           Text="TRB-51cb224a-3af2-44e3-87e4-90931ba97594"
                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                           TextColor="#E8F5EE"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>

                <Button Grid.Column="{OnIdiom Phone=0, Desktop=2}"
                        Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                        Grid.ColumnSpan="{OnIdiom Phone=2, Desktop=1}"
                        Text="Cerrar Sesión"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="{OnIdiom Phone=11, Desktop=12}"
                        Padding="{OnIdiom Phone='8,4', Desktop='12,6'}"
                        HorizontalOptions="{OnIdiom Phone=Start, Desktop=End}"
                        Clicked="OnLogoutClicked"/>
            </Grid>

            <!-- HORAS DE ESTA SEMANA -->
            <Frame BackgroundColor="White"
                   BorderColor="#D6DAD7"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Horas de esta semana"
                           FontSize="{OnIdiom Phone=13, Desktop=14}"
                           FontAttributes="Bold"
                           TextColor="#2E3A34"/>
                    <Label x:Name="WeeklyHoursLabel"
                           Text="0h"
                           FontSize="{OnIdiom Phone=22, Desktop=24}"
                           FontAttributes="Bold"
                           TextColor="#2E3A34"/>
                </VerticalStackLayout>
            </Frame>

            <!-- PAGO NETO -->
            <Frame BackgroundColor="#9EC9B4"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Pago Neto Estimado"
                           FontSize="{OnIdiom Phone=13, Desktop=14}"
                           TextColor="White"/>
                    <Label x:Name="NetPayLabel"
                           Text="B/.0.00"
                           FontSize="{OnIdiom Phone=22, Desktop=24}"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <!-- DESGLOSE -->
            <Frame BorderColor="#D6DAD7"
                   BackgroundColor="White"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Desglose de Pago Semanal"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#2E3A34"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Devengado Bruto:" TextColor="#2E3A34"/>
                        <Label x:Name="GrossAmountLabel"
                               Grid.Column="1"
                               Text="B/.0.00"
                               HorizontalTextAlignment="End"
                               TextColor="#2E3A34"/>
                    </Grid>

                    <Frame BackgroundColor="#FFF5F5"
                           BorderColor="#FCA5A5"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="DESCUENTOS:"
                                   FontAttributes="Bold"
                                   TextColor="#DC2626"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Social (9%)" TextColor="#2E3A34"/>
                                <Label x:Name="SsDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Educativo (1.25%)" TextColor="#2E3A34"/>
                                <Label x:Name="SeDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Sindicato" TextColor="#2E3A34"/>
                                <Label x:Name="UnionDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.1.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="#DC2626"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#9EC9B4"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="TOTAL A RECIBIR:"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label x:Name="TotalNetLabel"
                                   Grid.Column="1"
                                   Text="B/.0.00"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="End"
                                   TextColor="White"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- ACTIVIDADES RECIENTES -->
            <Frame BorderColor="#D6DAD7"
                   BackgroundColor="White"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Actividades Recientes"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#2E3A34"/>

                    <!-- Tabla con scroll horizontal para móvil -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <VerticalStackLayout Spacing="0"
                                             MinimumWidthRequest="{OnIdiom Phone=520, Desktop=0}">

                            <!-- HEADER TABLA -->
                            <Grid ColumnDefinitions="72,*,80,60,80,80"
                                  ColumnSpacing="8"
                                  Padding="0,0,0,8">
                                <Label Text="FECHA"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="1"
                                       Text="ACTIVIDAD"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="2"
                                       Text="LOTE"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="3"
                                       Text="HORAS"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="4"
                                       Text="TARIFA"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="5"
                                       Text="MONTO"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       TextColor="#6B7280"/>
                            </Grid>

                            <!-- Separador -->
                            <BoxView HeightRequest="1" BackgroundColor="#EEEBE5" Margin="0,0,0,4"/>

                            <!-- FILAS -->
                            <CollectionView x:Name="ActivitiesCollection">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="0">
                                            <Grid ColumnDefinitions="72,*,80,60,80,80"
                                                  ColumnSpacing="8"
                                                  Padding="0,10">

                                                <Label Text="{Binding Fecha}"
                                                       FontSize="11"
                                                       TextColor="#9CA3AF"
                                                       VerticalOptions="Center"/>

                                                <Label Grid.Column="1"
                                                       Text="{Binding Actividad}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#2E3A34"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation"/>

                                                <!-- Lote: muestra nombre corto o trunca UUID -->
                                                <Label Grid.Column="2"
                                                       Text="{Binding Lote}"
                                                       FontSize="11"
                                                       TextColor="#6B7280"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation"/>

                                                <Label Grid.Column="3"
                                                       Text="{Binding Horas}"
                                                       FontSize="11"
                                                       HorizontalTextAlignment="End"
                                                       TextColor="#2E3A34"
                                                       VerticalOptions="Center"/>

                                                <Label Grid.Column="4"
                                                       Text="{Binding Tarifa}"
                                                       FontSize="11"
                                                       HorizontalTextAlignment="End"
                                                       TextColor="#9EC9B4"
                                                       VerticalOptions="Center"/>

                                                <Label Grid.Column="5"
                                                       Text="{Binding Monto}"
                                                       FontSize="11"
                                                       HorizontalTextAlignment="End"
                                                       TextColor="#9EC9B4"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <!-- Separador de fila -->
                                            <BoxView HeightRequest="1" BackgroundColor="#F3F4F6"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </ScrollView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
