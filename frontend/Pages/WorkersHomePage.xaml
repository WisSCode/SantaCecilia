<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="frontend.Pages.WorkersHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BoneWhite}">

    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone='16,14', Desktop='24'}"
                             Spacing="{OnIdiom Phone=16, Desktop=20}">

            <!-- HEADER -->
            <Grid BackgroundColor="{StaticResource BrandSkyBlue}"
                  Padding="{OnIdiom Phone='16,10,16,10', Desktop='20,12,20,12'}"
                  ColumnDefinitions="{OnIdiom Phone='Auto,*', Desktop='Auto,*,Auto'}"
                  RowDefinitions="Auto"
                  RowSpacing="0"
                  ColumnSpacing="{OnIdiom Phone=12, Desktop=16}">

                <!-- Avatar con iniciales -->
                <Frame WidthRequest="42"
                       HeightRequest="42"
                       CornerRadius="0"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="0"
                       Margin="0"
                       VerticalOptions="Center"
                       HorizontalOptions="Start">
                    <Label x:Name="AvatarLabel"
                           Text="-"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}"/>
                </Frame>

                <VerticalStackLayout Grid.Column="1" 
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label x:Name="WorkerNameLabel"
                           Text="Cargando..."
                           FontAttributes="Bold"
                           FontSize="{OnIdiom Phone=14, Desktop=16}"
                           TextColor="White"
                           Margin="0"/>
                    <Label x:Name="WorkerCedulaLabel"
                           FontAttributes="Bold"
                           Text="Cédula: —"
                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                           TextColor="#E8F5EE"
                           Margin="0"/>
                    <Label x:Name="WorkerCodeLabel"
                           Text=""
                           FontAttributes="Bold"
                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                           TextColor="#E8F5EE"
                           LineBreakMode="TailTruncation"
                           Margin="0"/>
                </VerticalStackLayout>

                <Button Grid.Column="{OnIdiom Phone=1, Desktop=2}"
                        Text="Cerrar Sesión"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        BorderColor="White"
                        BorderWidth="1"
                        FontAttributes="Bold"
                        FontSize="{OnIdiom Phone=11, Desktop=12}"
                        Padding="{OnIdiom Phone='10,5', Desktop='14,7'}"
                        CornerRadius="3"
                        Margin="0"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        Clicked="OnLogoutClicked"/>
            </Grid>

            <!-- HORAS DE ESTA SEMANA -->
            <Frame BackgroundColor="White"
                   BorderColor="{StaticResource Border}"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Horas de esta semana"
                           FontSize="{OnIdiom Phone=13, Desktop=14}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label x:Name="WeeklyHoursLabel"
                           Text="0h"
                           FontSize="{OnIdiom Phone=22, Desktop=24}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- PAGO NETO -->
            <Frame BackgroundColor="White"
                   BorderColor="{StaticResource Border}"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Pago Neto Estimado"
                           FontSize="{OnIdiom Phone=13, Desktop=14}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label x:Name="NetPayLabel"
                           Text="B/.0.00"
                           FontSize="{OnIdiom Phone=22, Desktop=24}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- DESGLOSE -->
            <Frame BorderColor="{StaticResource Border}"
                   BackgroundColor="White"
                   CornerRadius="0"
                   Padding="{OnIdiom Phone=12, Desktop=16}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Desglose de Pago Semanal"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Devengado Bruto:" TextColor="{StaticResource TextPrimary}"/>
                        <Label x:Name="GrossAmountLabel"
                               Grid.Column="1"
                               Text="B/.0.00"
                               HorizontalTextAlignment="End"
                               TextColor="{StaticResource TextPrimary}"/>
                    </Grid>

                    <Frame BackgroundColor="{StaticResource AccentNeutral}"
                           BorderColor="{StaticResource Danger}"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="DESCUENTOS:"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource DangerDark}"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Social (9%)" TextColor="{StaticResource TextPrimary}"/>
                                <Label x:Name="SsDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="{StaticResource DangerDark}"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Seguro Educativo (1.25%)" TextColor="{StaticResource TextPrimary}"/>
                                <Label x:Name="SeDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.0.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="{StaticResource DangerDark}"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Sindicato" TextColor="{StaticResource TextPrimary}"/>
                                <Label x:Name="UnionDeductionLabel"
                                       Grid.Column="1"
                                       Text="-B/.1.00"
                                       HorizontalTextAlignment="End"
                                       TextColor="{StaticResource DangerDark}"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="{StaticResource BrandSkyBlue}"
                           CornerRadius="0"
                           Padding="{OnIdiom Phone=10, Desktop=12}"
                           HasShadow="False">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="TOTAL A RECIBIR:"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label x:Name="TotalNetLabel"
                                   Grid.Column="1"
                                   Text="B/.0.00"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="End"
                                   TextColor="White"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- ACTIVIDADES RECIENTES -->
            <Border Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

                    <!-- Header verde de la tabla -->
                    <Grid BackgroundColor="{StaticResource BrandSkyBlue}" Padding="16,12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Actividades Recientes"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label Text="Últimas actividades registradas en la semana"
                                   FontSize="11"
                                   TextColor="#E8F5EE" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Tabla con scroll horizontal -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <VerticalStackLayout Spacing="0">
                            <!-- Encabezados de columna -->
                            <Grid Padding="16,10"
                                  ColumnDefinitions="{OnIdiom Phone='65,100,65,65,65,65', Desktop='0.8*,2*,0.8*,0.8*,0.8*,0.8*'}"
                                  ColumnSpacing="8"
                                  BackgroundColor="{StaticResource SurfaceSecondary}">
                                <Label Text="FECHA" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="ACTIVIDAD" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="2" Text="LOTE" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="3" Text="HORAS" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="4" Text="TARIFA" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="5" Text="MONTO" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="{StaticResource TextSecondary}" />
                            </Grid>

                            <!-- Filas -->
                            <CollectionView x:Name="ActivitiesCollection" SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout Padding="40,30" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="Sin actividades"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalOptions="Center" />
                                        <Label Text="No hay actividades registradas esta semana"
                                               FontSize="12"
                                               TextColor="{StaticResource TextTertiary}"
                                               HorizontalOptions="Center"
                                               Margin="0,8,0,0" />
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="0">
                                            <Border Stroke="Transparent" StrokeThickness="0"
                                                    Padding="16,12" BackgroundColor="White"
                                                    MinimumHeightRequest="50">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='65,100,65,65,65,65', Desktop='0.8*,2*,0.8*,0.8*,0.8*,0.8*'}"
                                                      ColumnSpacing="8"
                                                      VerticalOptions="Center">
                                                    <Label Text="{Binding Fecha}"
                                                           FontSize="11"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Actividad}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Lote}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="End"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="3"
                                                           Text="{Binding Horas}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="End"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="4"
                                                           Text="{Binding Tarifa}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="End"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="5"
                                                           Text="{Binding Monto}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="End"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderLight}" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
