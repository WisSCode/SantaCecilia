<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.NewBatchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Fill" Padding="{OnIdiom Phone=12, Desktop=20}">
        <Border HorizontalOptions="Fill"
                MaximumWidthRequest="400"
                Stroke="#D6DAD7"
                StrokeThickness="1"
                BackgroundColor="White">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- ENCABEZADO -->
                  <Grid BackgroundColor="#9EC9B4"
                     Padding="{OnIdiom Phone=16, Desktop=20}"
                     ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nuevo Lote"
                           FontSize="{OnIdiom Phone=15, Desktop=16}"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="Complete la informacion del lote"
                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                               TextColor="#F2F7F4" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="X"
                        FontSize="{OnIdiom Phone=14, Desktop=16}"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Padding="4"
                            VerticalOptions="Start"
                            Clicked="OnCancelClicked" />
                </Grid>

                <!-- FORMULARIO -->
                <VerticalStackLayout Padding="{OnIdiom Phone=16, Desktop=24}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                    <!-- NOMBRE DEL LOTE -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nombre del lote"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Entry x:Name="NameEntry"
                                   Placeholder="Ej: Lote A-1"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#2E3A34"
                                   BackgroundColor="White"
                                   TextChanged="OnFieldChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- REFERENCIA DE LOCALIZACION -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Referencia de localizacion"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Entry x:Name="LocationEntry"
                                   Placeholder="Ej: Sector norte, fila 3"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#2E3A34"
                                   BackgroundColor="White"
                                   TextChanged="OnFieldChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- BOTONES -->
                      <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                          RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                          ColumnSpacing="12"
                          RowSpacing="{OnIdiom Phone=10, Desktop=0}"
                          Margin="0,8,0,0">
                        <Button Grid.Column="0"
                              Grid.Row="{OnIdiom Phone=0, Desktop=0}"
                                Text="Cancelar"
                              HeightRequest="{OnIdiom Phone=40, Desktop=44}"
                              FontSize="{OnIdiom Phone=12, Desktop=13}"
                                BackgroundColor="Transparent"
                                TextColor="#2E3A34"
                                FontAttributes="Bold"
                                BorderColor="#D6DAD7"
                                BorderWidth="1"
                                Clicked="OnCancelClicked" />
                        <Button x:Name="CreateButton"
                            Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                                Text="Crear Lote"
                            HeightRequest="{OnIdiom Phone=40, Desktop=44}"
                            FontSize="{OnIdiom Phone=12, Desktop=13}"
                                BackgroundColor="#9EC9B4"
                                TextColor="White"
                                FontAttributes="Bold"
                                IsEnabled="False"
                                Clicked="OnCreateClicked" />
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
