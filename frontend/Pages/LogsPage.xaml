<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.LogsPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12"
                    VerticalOptions="Center"
                    Padding="0">

                    <!-- Text -->
                    <VerticalStackLayout Spacing="2"
                                        VerticalOptions="Center"
                                        Grid.Column="0">

                        <Label Text="Logs"
                            FontSize="{OnIdiom Phone=18, Desktop=20}"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Registro de eventos del sistema"
                            FontSize="{OnIdiom Phone=10, Desktop=11}"
                            TextColor="{StaticResource TextSecondary}"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Summary Stats -->
                    <Grid ColumnDefinitions="{OnIdiom Phone='*,*', Desktop='*,*'}"
                        RowDefinitions="Auto"
                        ColumnSpacing="{OnIdiom Phone=8, Desktop=12}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalLogsLabel" Text="0" FontSize="{OnIdiom Phone=18, Desktop=24}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Total eventos" FontSize="{OnIdiom Phone=10, Desktop=11}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                        <Border Grid.Column="1"
                            Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="Last24hLabel" Text="0" FontSize="{OnIdiom Phone=18, Desktop=24}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Ultimas 24h" FontSize="{OnIdiom Phone=10, Desktop=11}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Search Bar -->
                <Border Style="{StaticResource CardFrame}" Padding="10">
                    <Entry x:Name="SearchEntry" Placeholder="Buscar evento..." TextChanged="OnSearchChanged" />
                </Border>

                <!-- Logs List -->
                <Border Style="{StaticResource CardFrame}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Bitacora de cambios" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="0">
                                <Grid Padding="10"
                                      ColumnDefinitions="{OnIdiom Phone='130,90,100,220,100', Desktop='1.4*,1*,1*,2.2*,1*'}"
                                      ColumnSpacing="8"
                                      BackgroundColor="{StaticResource SurfaceSecondary}">
                                    <Label Text="FECHA" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="1" Text="ACCION" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Start" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="2" Text="ENTIDAD" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Start" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="3" Text="DETALLE" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Start" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="4" Text="USUARIO" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Start" TextColor="{StaticResource TextSecondary}" />
                                </Grid>

                                <CollectionView x:Name="LogsList" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Border}" StrokeThickness="1" Padding="10" Margin="0,1">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='130,90,100,220,100', Desktop='1.4*,1*,1*,2.2*,1*'}" ColumnSpacing="8">
                                                    
                                                    <!-- Columna 0: Fecha -->
                                                    <Label Text="{Binding DateDisplay}" 
                                                        FontSize="11" 
                                                        TextColor="{StaticResource TextPrimary}" 
                                                        VerticalOptions="Center" 
                                                        HorizontalTextAlignment="Start" />

                                                    <!-- Columna 1: Acción (Dentro de un Frame) -->
                                                    <Frame Grid.Column="1"
                                                        BackgroundColor="{Binding ActionBgColor}"
                                                        Padding="6,3"
                                                        CornerRadius="4"
                                                        HasShadow="False"
                                                        BorderColor="Transparent"
                                                        HorizontalOptions="Start"
                                                        VerticalOptions="Center">
                                                        <Label Text="{Binding ActionText}" 
                                                            FontSize="10" 
                                                            TextColor="{Binding ActionTextColor}" 
                                                            FontAttributes="Bold" />
                                                    </Frame>

                                                    <!-- Columna 2: Entidad -->
                                                    <Label Grid.Column="2" 
                                                        Text="{Binding Entity}" 
                                                        FontSize="11"
                                                        HorizontalTextAlignment="Start" 
                                                        TextColor="{StaticResource TextPrimary}" 
                                                        VerticalOptions="Center" />

                                                    <!-- Columna 3: Detalle -->
                                                    <Label Grid.Column="3" 
                                                        Text="{Binding Message}" 
                                                        FontSize="11" 
                                                        HorizontalTextAlignment="Start"
                                                        TextColor="{StaticResource TextPrimary}" 
                                                        LineBreakMode="TailTruncation" />

                                                    <!-- Columna 4: Usuario -->
                                                    <Label Grid.Column="4" 
                                                        Text="{Binding ActorId}" 
                                                        FontSize="11"
                                                        HorizontalTextAlignment="Start" 
                                                        TextColor="{StaticResource TextPrimary}" 
                                                        VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
