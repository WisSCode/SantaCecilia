<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.LogsPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Header -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Logs" Style="{StaticResource Heading2}" />
                    <Label Text="Registro de eventos del sistema" Style="{StaticResource BodySecondary}" />
                </VerticalStackLayout>

                <!-- Summary Stats -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalLogsLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Total eventos" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="Last24hLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Ultimas 24h" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Logs List -->
                <Border Style="{StaticResource CardFrame}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Bitacora de cambios" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <Grid Padding="10" ColumnDefinitions="1.4*,1*,1*,2.2*,1*" BackgroundColor="{StaticResource SurfaceSecondary}">
                            <Label Text="FECHA" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="1" Text="ACCION" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="2" Text="ENTIDAD" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="3" Text="DETALLE" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="4" Text="USUARIO" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                        </Grid>

                        <CollectionView x:Name="LogsList" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="{StaticResource Border}" StrokeThickness="1" Padding="10">
                                        <Grid ColumnDefinitions="1.4*,1*,1*,2.2*,1*" ColumnSpacing="8">
                                            <Label Text="{Binding DateDisplay}" FontSize="11" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{Binding ActionBgColor}"
                                                    Padding="6,3"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding ActionText}" FontSize="10" TextColor="{Binding ActionTextColor}" FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="2" Text="{Binding Entity}" FontSize="11" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            <Label Grid.Column="3" Text="{Binding Message}" FontSize="11" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="4" Text="{Binding ActorId}" FontSize="11" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
