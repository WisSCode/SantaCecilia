<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.WorkersPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12"
                    VerticalOptions="Center"
                    Padding="0">

                    <!-- Text -->
                    <VerticalStackLayout Spacing="2"
                                        VerticalOptions="Center"
                                        Grid.Column="0">

                        <Label Text="Trabajadores"
                            FontSize="{OnIdiom Phone=18, Desktop=20}"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Gestión de personal de la finca"
                            FontSize="{OnIdiom Phone=10, Desktop=11}"
                            TextColor="{StaticResource TextSecondary}"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Button -->
                    <Button Grid.Column="1"
                            Text="+ Nuevo Trabajador"
                            Clicked="OnAddWorkerClicked"
                            BackgroundColor="#9EC9B4"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            HeightRequest="{OnIdiom Phone=36, Desktop=40}"
                            Padding="{OnIdiom Phone='12,0', Desktop='16,0'}"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                </Grid>

                <!-- 3 Stat Cards -->
                    <Grid ColumnDefinitions="{OnIdiom Phone='*,*,*', Desktop='*,*,*'}"
                        RowDefinitions="Auto"
                        ColumnSpacing="{OnIdiom Phone=8, Desktop=12}">

                    <!-- Activos -->
                    <Border Grid.Column="0"
                            Grid.Row="{OnIdiom Phone=0, Desktop=0}"
                            Stroke="#D6DAD7" StrokeThickness="1"
                            BackgroundColor="White" Padding="{OnIdiom Phone=12, Desktop=14}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Activos"
                                        FontSize="{OnIdiom Phone=10, Desktop=12}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="ActiveCount"
                                   Text="0"
                                FontSize="{OnIdiom Phone=18, Desktop=24}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Trabajadores activos"
                                FontSize="{OnIdiom Phone=10, Desktop=11}"
                                   TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Inactivos -->
                        <Border Grid.Column="1"
                            Stroke="#D6DAD7" StrokeThickness="1"
                            BackgroundColor="White" Padding="{OnIdiom Phone=12, Desktop=14}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Inactivos"
                                        FontSize="{OnIdiom Phone=10, Desktop=12}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="InactiveCount"
                                   Text="0"
                                FontSize="{OnIdiom Phone=18, Desktop=24}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Trabajadores inactivos"
                                FontSize="{OnIdiom Phone=10, Desktop=11}"
                                   TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Total -->
                        <Border Grid.Column="2"
                            Stroke="Transparent" StrokeThickness="0"
                            BackgroundColor="#9EC9B4" Padding="{OnIdiom Phone=12, Desktop=14}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Total"
                                        FontSize="{OnIdiom Phone=10, Desktop=12}"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="TotalCount"
                                   Text="0"
                                FontSize="{OnIdiom Phone=18, Desktop=24}"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label Text="Total trabajadores"
                                FontSize="{OnIdiom Phone=10, Desktop=11}"
                                   TextColor="#E8F5EE" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tabla de Trabajadores (con buscador y lista) -->
                <Border Stroke="Transparent" StrokeThickness="0" BackgroundColor="White" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="0">
                        <!-- Header verde -->
                        <Grid BackgroundColor="#9EC9B4" Padding="16,12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Lista de Trabajadores"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label x:Name="WorkersCountLabel"
                                       Text="0 trabajadores encontrados"
                                       FontSize="11"
                                       TextColor="#E8F5EE" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Buscador -->
                        <Border Stroke="#EEEBE5"
                                StrokeThickness="0,0,0,1"
                                Padding="12,8"
                                BackgroundColor="White">
                            <Entry x:Name="SearchEntry"
                                   Placeholder="Buscar trabajador..."
                                   FontSize="12"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource TextPrimary}"
                                   TextChanged="OnSearchChanged" />
                        </Border>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="0">
                                <!-- Encabezados de columna -->
                                <Grid Padding="16,10"
                                      ColumnDefinitions="{OnIdiom Phone='70,90,90,90,90,90', Desktop='0.8*,1.2*,1.4*,1.4*,0.9*,1*'}"
                                      ColumnSpacing="6"
                                      BackgroundColor="#FAFAF7">
                                    <Label x:Name="HeaderId" Text="ID &#x2191;" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortById" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="HeaderName" Grid.Column="1" Text="NOMBRE" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByName" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="HeaderLastName" Grid.Column="2" Text="APELLIDO" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByLastName" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="HeaderId2" Grid.Column="3" Text="CÉDULA" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByIdentification" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="HeaderStatus" Grid.Column="4" Text="ESTADO" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSortByStatus" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Grid.Column="5" Text="ACCIONES" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                </Grid>

                                <!-- Filas -->
                                <CollectionView x:Name="WorkersList" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="#EEEBE5" StrokeThickness="0,0,0,1"
                                                    Padding="16,10" BackgroundColor="White">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='70,90,90,90,90,90', Desktop='0.8*,1.2*,1.4*,1.4*,0.9*,1*'}"
                                                      ColumnSpacing="6">

                                                   <!-- ID -->
                                                   <Label Text="{Binding DisplayId}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center" />

                                                   <!-- NOMBRE -->
                                                   <Label Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       VerticalOptions="Center" />

                                                   <!-- APELLIDO -->
                                                   <Label Grid.Column="2"
                                                       Text="{Binding LastName}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       VerticalOptions="Center" />

                                                   <!-- CEDULA -->
                                                   <Label Grid.Column="3"
                                                       Text="{Binding Identification}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center" />

                                                    <!-- ESTADO -->
                                                    <Border Grid.Column="4"
                                                            BackgroundColor="{Binding StatusBgColor}"
                                                            Padding="8,4"
                                                            HorizontalOptions="Start"
                                                            VerticalOptions="Center"
                                                            StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="4" />
                                                        </Border.StrokeShape>
                                                        <Label Text="{Binding StatusText}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="{Binding StatusTextColor}" />
                                                    </Border>

                                                    <!-- ACCIONES -->
                                                    <HorizontalStackLayout Grid.Column="5" Spacing="10" VerticalOptions="Center" HorizontalOptions="End">
                                                        <Label Text="Editar"
                                                               TextColor="#2E7D5B"
                                                               FontSize="11"
                                                               TextDecorations="None">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Tapped="OnEditWorkerTapped"
                                                                    CommandParameter="{Binding .}" />
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                        <Label Text="{Binding ToggleText}"
                                                               TextColor="{Binding ToggleColor}"
                                                               FontSize="11"
                                                               TextDecorations="None">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Tapped="OnToggleActiveTapped"
                                                                    CommandParameter="{Binding .}" />
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </HorizontalStackLayout>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
