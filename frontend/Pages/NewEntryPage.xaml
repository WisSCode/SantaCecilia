<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.NewEntryPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000">

    <ScrollView VerticalOptions="Center" HorizontalOptions="Fill">
        <Grid Padding="{OnIdiom Phone=12, Desktop=20}" HorizontalOptions="Fill" VerticalOptions="Center">
            <Border HorizontalOptions="Fill"
                    MaximumWidthRequest="440"
                    Stroke="#D6DAD7"
                    StrokeThickness="1"
                    BackgroundColor="White">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*">

                    <!-- ENCABEZADO -->
                          <Grid Grid.Row="0"
                             BackgroundColor="#9EC9B4"
                             Padding="{OnIdiom Phone=16, Desktop=20}"
                             ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Registrar Tiempo"
                                FontSize="{OnIdiom Phone=15, Desktop=16}"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label Text="Complete la informacion de la actividad realizada"
                                FontSize="{OnIdiom Phone=10, Desktop=11}"
                                   TextColor="#F2F7F4" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="X"
                                FontSize="{OnIdiom Phone=14, Desktop=16}"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Padding="4"
                                VerticalOptions="Start"
                                Clicked="OnCancelClicked" />
                    </Grid>

                    <!-- FORMULARIO -->
                    <VerticalStackLayout Grid.Row="1" Padding="{OnIdiom Phone=16, Desktop=24}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                        <!-- TRABAJADOR -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Trabajador"
                                   FontSize="{OnIdiom Phone=11, Desktop=12}"
                                   FontAttributes="Bold"
                                   TextColor="#2E3A34" />
                            <Picker x:Name="WorkerPicker"
                                    Title="-- Seleccionar --"
                                    FontSize="{OnIdiom Phone=12, Desktop=13}"
                                    TextColor="#2E3A34"
                                    TitleColor="#8A9490"
                                    HorizontalOptions="Fill"
                                    SelectedIndexChanged="OnFieldChanged" />
                        </VerticalStackLayout>

                        <!-- ACTIVIDAD -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Actividad"
                                   FontSize="{OnIdiom Phone=11, Desktop=12}"
                                   FontAttributes="Bold"
                                   TextColor="#2E3A34" />

                            <!-- Barra de busqueda -->
                            <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                    BackgroundColor="White" HeightRequest="{OnIdiom Phone=40, Desktop=44}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                <Entry x:Name="ActivitySearchEntry"
                                       Placeholder="Buscar actividad..."
                                       FontSize="{OnIdiom Phone=12, Desktop=13}"
                                       TextColor="#2E3A34"
                                       BackgroundColor="Transparent"
                                       TextChanged="OnActivitySearchChanged" />
                            </Border>

                            <!-- Lista de actividades -->
                            <Border Stroke="#D6DAD7" StrokeThickness="1" BackgroundColor="White"
                                    HeightRequest="150">
                                <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                <CollectionView x:Name="ActivityListView"
                                                SelectionMode="Single"
                                                SelectionChanged="OnActivitySelected">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,10"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding BackgroundColor}">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Text="{Binding Name}"
                                                       FontSize="{OnIdiom Phone=12, Desktop=13}"
                                                           FontAttributes="Bold"
                                                           TextColor="#2E3A34"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding RateDisplay}"
                                                       FontSize="{OnIdiom Phone=12, Desktop=13}"
                                                           FontAttributes="Bold"
                                                           TextColor="#9EC9B4"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Border>
                        </VerticalStackLayout>

                        <!-- LOTE -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Lote"
                                   FontSize="{OnIdiom Phone=11, Desktop=12}"
                                   FontAttributes="Bold"
                                   TextColor="#2E3A34" />
                            <Picker x:Name="LotePicker"
                                    Title="-- Seleccionar --"
                                    FontSize="{OnIdiom Phone=12, Desktop=13}"
                                    TextColor="#2E3A34"
                                    TitleColor="#8A9490"
                                    HorizontalOptions="Fill"
                                    SelectedIndexChanged="OnFieldChanged" />
                        </VerticalStackLayout>

                        <!-- FECHA -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Fecha"
                                   FontSize="{OnIdiom Phone=11, Desktop=12}"
                                   FontAttributes="Bold"
                                   TextColor="#2E3A34" />
                            <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                    BackgroundColor="White" HeightRequest="{OnIdiom Phone=40, Desktop=44}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                <DatePicker x:Name="EntryDatePicker"
                                            FontSize="{OnIdiom Phone=12, Desktop=13}"
                                            TextColor="#2E3A34"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- HORAS / MINUTOS -->
                        <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                              RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                              ColumnSpacing="12"
                              RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                            <VerticalStackLayout Grid.Column="0"
                                                 Grid.Row="{OnIdiom Phone=0, Desktop=0}"
                                                 Spacing="6">
                                <Label Text="Horas"
                                       FontSize="{OnIdiom Phone=11, Desktop=12}"
                                       FontAttributes="Bold"
                                       TextColor="#2E3A34" />
                                <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                        BackgroundColor="White" HeightRequest="{OnIdiom Phone=40, Desktop=44}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                    <Entry x:Name="HoursEntry"
                                           Keyboard="Numeric"
                                           Text="8"
                                           FontSize="{OnIdiom Phone=12, Desktop=13}"
                                           TextColor="#2E3A34"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"
                                           TextChanged="OnFieldChanged" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                                                 Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                                                 Spacing="6">
                                <Label Text="Minutos"
                                       FontSize="{OnIdiom Phone=11, Desktop=12}"
                                       FontAttributes="Bold"
                                       TextColor="#2E3A34" />
                                <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                        BackgroundColor="White" HeightRequest="{OnIdiom Phone=40, Desktop=44}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                    <Entry x:Name="MinutesEntry"
                                           Keyboard="Numeric"
                                           Text="0"
                                           Placeholder="0-59"
                                           FontSize="{OnIdiom Phone=12, Desktop=13}"
                                           TextColor="#2E3A34"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"
                                           TextChanged="OnFieldChanged" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- BOTONES -->
                        <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                            RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                            ColumnSpacing="12"
                            RowSpacing="{OnIdiom Phone=10, Desktop=0}"
                            Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                Grid.Row="{OnIdiom Phone=0, Desktop=0}"
                                    Text="Cancelar"
                                HeightRequest="{OnIdiom Phone=40, Desktop=44}"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                    BackgroundColor="Transparent"
                                    TextColor="#2E3A34"
                                    FontAttributes="Bold"
                                    BorderColor="#D6DAD7"
                                    BorderWidth="1"
                                    Clicked="OnCancelClicked" />
                            <Button x:Name="SaveButton"
                                    Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                                    Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                                    Text="Guardar Registro"
                                    HeightRequest="{OnIdiom Phone=40, Desktop=44}"
                                    FontSize="{OnIdiom Phone=12, Desktop=13}"
                                    BackgroundColor="#9EC9B4"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    IsEnabled="False"
                                    Clicked="OnSaveClicked" />
                        </Grid>

                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
