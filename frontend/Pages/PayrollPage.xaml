<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.PayrollPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Text="Boletas de Pago"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Calculo y gestion de nomina semanal"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Week Selector -->
                <Border Stroke="#D6DAD7" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Seleccionar Semana de Pago"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    Stroke="#D6DAD7" StrokeThickness="1"
                                    Padding="10,0" BackgroundColor="White" HeightRequest="44">
                                <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                <DatePicker x:Name="PayrollWeekPicker"
                                            FontSize="13"
                                            TextColor="{StaticResource TextPrimary}"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Center"
                                            DateSelected="OnWeekChanged" />
                            </Border>
                            <Button Grid.Column="1"
                                    Text="Procesar Nomina Completa"
                                    BackgroundColor="#9EC9B4"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    HeightRequest="44"
                                    Padding="16,0"
                                    Clicked="OnProcessPayrollClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- 3 Stat Cards -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                    <!-- Monto Bruto -->
                    <Border Grid.Column="0"
                            Stroke="#D6DAD7" StrokeThickness="1"
                            BackgroundColor="White" Padding="14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Monto Bruto" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label x:Name="GrossTotal" Text="B/.0.00"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="WorkerCountLabel" Text="0 trabajadores"
                                   FontSize="11" TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Descuentos -->
                    <Border Grid.Column="1"
                            Stroke="#D6DAD7" StrokeThickness="1"
                            BackgroundColor="White" Padding="14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Descuentos" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label x:Name="DeductionsTotal" Text="B/.0.00"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Legales + Sindicales"
                                   FontSize="11" TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Monto Neto -->
                    <Border Grid.Column="2"
                            Stroke="Transparent" StrokeThickness="0"
                            BackgroundColor="#9EC9B4" Padding="14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Monto Neto" FontSize="12" FontAttributes="Bold"
                                   TextColor="White" />
                            <Label x:Name="NetTotal" Text="B/.0.00"
                                   FontSize="24" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Total a pagar"
                                   FontSize="11" TextColor="#E8F5EE" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tabla de Boletas -->
                <Border Stroke="Transparent" StrokeThickness="0"
                        BackgroundColor="White" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="0">

                        <!-- Header verde -->
                        <Grid BackgroundColor="#9EC9B4" Padding="16,12"
                              ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="PayrollWeekLabel"
                                       Text="Semana del ..."
                                       FontSize="15" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Fecha limite de pago: Sabado 3:00 PM"
                                       FontSize="11" TextColor="#E8F5EE" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="Exportar"
                                   FontSize="11" TextColor="White"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Encabezados -->
                        <Grid Padding="16,10"
                              ColumnDefinitions="0.8*,1.6*,1.8*,0.8*,1*,1.1*,1*,0.9*,0.7*"
                              BackgroundColor="#FAFAF7">
                            <Label Text="CODIGO" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="1" Text="TRABAJADOR" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="2" Text="TIPO" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="3" Text="HORAS" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="4" Text="BRUTO" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="5" Text="DESCUENTOS" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="6" Text="NETO" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="7" Text="ESTADO" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="8" Text="ACCIONES" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                        </Grid>

                        <!-- Filas -->
                        <CollectionView x:Name="PayrollList" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="#EEEBE5" StrokeThickness="0,0,0,1"
                                            Padding="16,10" BackgroundColor="White">
                                        <Grid ColumnDefinitions="0.8*,1.6*,1.8*,0.8*,1*,1.1*,1*,0.9*,0.7*"
                                              ColumnSpacing="4">

                                            <!-- CODIGO -->
                                            <Label Text="{Binding DisplayId}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" />

                                            <!-- TRABAJADOR con inicial -->
                                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                                <Border BackgroundColor="{Binding InitialColor}"
                                                        WidthRequest="26" HeightRequest="26"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 13">
                                                    <Label Text="{Binding Initial}"
                                                           FontSize="11" FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                </Border>
                                                <Label Text="{Binding WorkerName}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                            </HorizontalStackLayout>

                                            <!-- TIPO -->
                                            <Border Grid.Column="2"
                                                    BackgroundColor="#E8F5EE"
                                                    Padding="6,3"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Center"
                                                    StrokeThickness="0">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                <Label Text="{Binding WorkerType}"
                                                       FontSize="10"
                                                       TextColor="#2E7D5B"
                                                       LineBreakMode="TailTruncation" />
                                            </Border>

                                            <!-- HORAS -->
                                            <Label Grid.Column="3"
                                                   Text="{Binding HoursDisplay}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" />

                                            <!-- BRUTO -->
                                            <Label Grid.Column="4"
                                                   Text="{Binding GrossDisplay}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" />

                                            <!-- DESCUENTOS -->
                                            <Label Grid.Column="5"
                                                   Text="{Binding DeductionsDisplay}"
                                                   FontSize="11"
                                                   TextColor="#C05858"
                                                   VerticalOptions="Center" />

                                            <!-- NETO -->
                                            <Label Grid.Column="6"
                                                   Text="{Binding NetDisplay}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" />

                                            <!-- ESTADO -->
                                            <Border Grid.Column="7"
                                                    BackgroundColor="{Binding StatusBgColor}"
                                                    Padding="6,3"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Center"
                                                    StrokeThickness="0">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                <Label Text="{Binding StatusText}"
                                                       FontSize="9" FontAttributes="Bold"
                                                       TextColor="{Binding StatusTextColor}" />
                                            </Border>

                                            <!-- ACCIONES -->
                                            <HorizontalStackLayout Grid.Column="8" Spacing="6" VerticalOptions="Center">
                                                <Label Text="Ver"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnViewTapped"
                                                                              CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                                <Label Text="Marcar"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding IsPending}">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnMarkPaidTapped"
                                                                              CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                                <Label Text="Imprimir"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnPrintTapped"
                                                                              CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </HorizontalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Fila de TOTALES -->
                        <Border Stroke="#EEEBE5" StrokeThickness="0,1,0,0"
                                Padding="16,12" BackgroundColor="#FAFAF7">
                            <Grid ColumnDefinitions="0.8*,1.6*,1.8*,0.8*,1*,1.1*,1*,0.9*,0.7*"
                                  ColumnSpacing="4">
                                <Label Text="TOTALES"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="4"
                                       x:Name="TotalGrossLabel"
                                       Text="B/.0.00"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="5"
                                       x:Name="TotalDeductionsLabel"
                                       Text="-B/.0.00"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="#C05858"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="6"
                                       x:Name="TotalNetLabel"
                                       Text="B/.0.00"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
