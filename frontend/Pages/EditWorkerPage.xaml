<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.EditWorkerPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Fill" Padding="{OnIdiom Phone=12, Desktop=20}">
        <Border HorizontalOptions="Fill"
                MaximumWidthRequest="400"
                Stroke="#D6DAD7"
                StrokeThickness="1"
                BackgroundColor="White">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- ENCABEZADO -->
                <Grid BackgroundColor="#9EC9B4" Padding="{OnIdiom Phone=14, Desktop=20}" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="{OnIdiom Phone=2, Desktop=4}">
                        <Label Text="Editar Trabajador"
                               FontSize="{OnIdiom Phone=15, Desktop=16}"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="Modifique la informacion del trabajador"
                               FontSize="{OnIdiom Phone=10, Desktop=11}"
                               TextColor="#F2F7F4" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="X"
                            FontSize="{OnIdiom Phone=14, Desktop=16}"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Padding="4"
                            VerticalOptions="Start"
                            Clicked="OnCancelClicked" />
                </Grid>

                <!-- FORMULARIO -->
                <VerticalStackLayout Padding="{OnIdiom Phone=14, Desktop=24}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                    <!-- NOMBRE -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nombre"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Entry x:Name="NameEntry"
                                   Placeholder="Ej: Juan"
                                   Keyboard="Text"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#2E3A34"
                                   BackgroundColor="White"
                                   TextChanged="OnFieldChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- APELLIDO -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Apellido"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Entry x:Name="LastNameEntry"
                                   Placeholder="Ej: Perez Gomez"
                                   Keyboard="Text"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#2E3A34"
                                   BackgroundColor="White"
                                   TextChanged="OnFieldChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- CEDULA -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Cedula"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Entry x:Name="IdentificationEntry"
                                   Placeholder="Ej: 8-123-456"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#2E3A34"
                                   BackgroundColor="White"
                                   TextChanged="OnFieldChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- BOTONES -->
                        <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                          RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                          ColumnSpacing="12"
                          RowSpacing="{OnIdiom Phone=10, Desktop=0}"
                          Margin="0,8,0,0">
                        <Button Grid.Column="0"
                                Text="Cancelar"
                            HeightRequest="{OnIdiom Phone=42, Desktop=44}"
                                BackgroundColor="Transparent"
                                TextColor="#2E3A34"
                                FontAttributes="Bold"
                                BorderColor="#D6DAD7"
                                BorderWidth="1"
                                Clicked="OnCancelClicked" />
                        <Button x:Name="UpdateButton"
                            Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                                Text="Guardar Cambios"
                            HeightRequest="{OnIdiom Phone=42, Desktop=44}"
                                BackgroundColor="#9EC9B4"
                                TextColor="White"
                                FontAttributes="Bold"
                                IsEnabled="False"
                                Clicked="OnUpdateClicked" />
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
