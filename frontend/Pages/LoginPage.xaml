<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
x:Class="frontend.Pages.LoginPage"
xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
xmlns:viewmodels="clr-namespace:frontend.ViewModels"
    x:DataType="viewmodels:LoginViewModel"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F7F7F3">

    <Grid VerticalOptions="Center"
          HorizontalOptions="Fill"
          Padding="{OnIdiom Phone='12,16', Desktop='0'}">
        <Border
            HorizontalOptions="Fill"
            MaximumWidthRequest="360"
            Stroke="#D6DAD7"
            StrokeThickness="1"
            BackgroundColor="White">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- ENCABEZADO -->
                <Grid BackgroundColor="#9EC9B4" Padding="{OnIdiom Phone=16, Desktop=24}">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                        <Image
                            Source="logo_santa_cecilia.png"
                            HeightRequest="{OnIdiom Phone=52, Desktop=64}"
                            WidthRequest="{OnIdiom Phone=52, Desktop=64}"
                            Aspect="AspectFit" />

                        <Label
                            Text="FINCA BANANERA SANTA CECILIA"
                            FontSize="{OnIdiom Phone=13, Desktop=14}"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Sistema de Gestión de Nómina"
                            FontSize="{OnIdiom Phone=10, Desktop=11}"
                            TextColor="#F2F7F4"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- FORMULARIO -->
                <VerticalStackLayout Padding="{OnIdiom Phone=16, Desktop=24}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                    <Label
                        Text="Iniciar Sesión"
                        FontSize="{OnIdiom Phone=15, Desktop=16}"
                        FontAttributes="Bold"
                        TextColor="#2E3A34" />

                    <!-- EMAIL -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Correo"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            FontAttributes="Bold"
                            TextColor="#2E3A34" />

                        <Entry
                            Placeholder="Ingrese su correo"
                            Keyboard="Email"
                            Text="{Binding Email}"
                            FontSize="{OnIdiom Phone=12, Desktop=13}"
                            TextColor="#2E3A34"
                            BackgroundColor="White" />
                    </VerticalStackLayout>

                    <!-- PASSWORD -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Contraseña"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            FontAttributes="Bold"
                            TextColor="#2E3A34" />

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <Entry
                                x:Name="PasswordEntry"
                                Grid.Column="0"
                                Placeholder="Ingrese su contraseña"
                                IsPassword="True"
                                Text="{Binding Password}"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                TextColor="#2E3A34"
                                BackgroundColor="White"
                                VerticalOptions="Center" />

                            <Button
                                x:Name="PasswordToggleButton"
                                Grid.Column="1"
                                Text="Mostrar"
                                FontSize="{OnIdiom Phone=11, Desktop=12}"
                                FontAttributes="Bold"
                                TextColor="#9EC9B4"
                                HeightRequest="30"
                                MinimumWidthRequest="{OnIdiom Phone=64, Desktop=70}"
                                Margin="8,0,0,0"
                                BackgroundColor="Transparent"
                                Padding="0"
                                VerticalOptions="Center"
                                Clicked="OnTogglePasswordVisibilityClicked" />
                        </Grid>

                        <Label
                            Text="¿Olvidaste tu contraseña?"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            TextColor="#9EC9B4"
                            HorizontalTextAlignment="Center">           
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>

                    <!-- BOTÓN INGRESAR -->
                    <Button
                        Text="Iniciar Sesión"
                        HeightRequest="{OnIdiom Phone=40, Desktop=44}"
                        FontSize="{OnIdiom Phone=12, Desktop=13}"
                        BackgroundColor="#9EC9B4"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="OnLoginClicked"
                        IsEnabled="True"/>

                    <!-- TEXTO REGISTRO -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label
                            Text="¿Eres nuevo?"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            TextColor="#2E3A34" />

                        <Label
                            Text="Registrate"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            FontAttributes="Bold"
                            TextColor="#9EC9B4">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>