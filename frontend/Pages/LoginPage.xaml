<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
x:Class="frontend.Pages.LoginPage"
xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F7F7F3">

    <Grid VerticalOptions="Center" HorizontalOptions="Center">
        <Border
            WidthRequest="360"
            Stroke="#D6DAD7"
            StrokeThickness="1"
            BackgroundColor="White">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- ENCABEZADO -->
                <Grid BackgroundColor="#9EC9B4" Padding="24">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                        <Image
                            Source="logo_santa_cecilia.png"
                            HeightRequest="64"
                            WidthRequest="64"
                            Aspect="AspectFit" />

                        <Label
                            Text="FINCA BANANERA SANTA CECILIA"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Sistema de Gestión de Nómina"
                            FontSize="11"
                            TextColor="#F2F7F4"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- FORMULARIO -->
                <VerticalStackLayout Padding="24" Spacing="16">

                    <Label
                        Text="Iniciar Sesión"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#2E3A34" />

                    <!-- EMAIL -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Correo"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="#2E3A34" />

                        <Entry
                            Placeholder="Ingrese su correo"
                            Keyboard="Email"
                            Text="{Binding Email}"
                            FontSize="13"
                            TextColor="#2E3A34"
                            BackgroundColor="White" />
                    </VerticalStackLayout>

                    <!-- PASSWORD -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Contraseña"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="#2E3A34" />

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <Entry
                                x:Name="PasswordEntry"
                                Grid.Column="0"
                                Placeholder="Ingrese su contraseña"
                                IsPassword="True"
                                Text="{Binding Password}"
                                FontSize="13"
                                TextColor="#2E3A34"
                                BackgroundColor="White"
                                VerticalOptions="Center" />

                            <Button
                                x:Name="PasswordToggleButton"
                                Grid.Column="1"
                                Text="Mostrar"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#9EC9B4"
                                HeightRequest="30"
                                MinimumWidthRequest="70"
                                Margin="8,0,0,0"
                                BackgroundColor="Transparent"
                                Padding="0"
                                VerticalOptions="Center"
                                Clicked="OnTogglePasswordVisibilityClicked" />
                        </Grid>

                        <Label
                            Text="¿Olvidaste tu contraseña?"
                            FontSize="12"
                            TextColor="#9EC9B4"
                            HorizontalTextAlignment="Center">           
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>

                    <!-- BOTÓN INGRESAR -->
                    <Button
                        Text="Iniciar Sesión"
                        HeightRequest="44"
                        BackgroundColor="#9EC9B4"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="OnLoginClicked"
                        IsEnabled="True"/>

                    <!-- TEXTO REGISTRO -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label
                            Text="¿Eres nuevo?"
                            FontSize="12"
                            TextColor="#2E3A34" />

                        <Label
                            Text="Registrate"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="#9EC9B4">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>