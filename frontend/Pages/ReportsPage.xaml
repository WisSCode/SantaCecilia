<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="frontend.Pages.ReportsPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView>
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Reportes" Style="{StaticResource Heading2}" />
                    <Label x:Name="ReportPeriodLabel" Style="{StaticResource BodySecondary}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,Auto,Auto'}"
                      RowDefinitions="{OnIdiom Phone='Auto,Auto,Auto', Desktop='Auto'}"
                      ColumnSpacing="10"
                      RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="10">
                        <Picker x:Name="ReportViewPicker"
                                Title="Vista"
                                SelectedIndexChanged="OnReportViewChanged">
                            <Picker.Items>
                                <x:String>Por actividad</x:String>
                                <x:String>Por trabajador</x:String>
                                <x:String>Por periodo</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>
                    <Button Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                            Text="Aplicar"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnApplyClicked" />
                    <Button Grid.Column="{OnIdiom Phone=0, Desktop=2}"
                            Grid.Row="{OnIdiom Phone=2, Desktop=0}"
                            Text="Descargar"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnDownloadClicked" />
                </Grid>

                <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                      RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                      ColumnSpacing="12"
                      RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Desde" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker x:Name="StartDatePicker" DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                            Style="{StaticResource CardFrame}" Padding="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Hasta" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker x:Name="EndDatePicker" DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                      RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                      ColumnSpacing="12"
                      RowSpacing="{OnIdiom Phone=10, Desktop=0}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalHoursLabel" Text="0.0h" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Horas Totales" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                            Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalAmountLabel" Text="B/.0.00" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Monto Total" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardFrame}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label x:Name="ReportTitleLabel" Text="Resumen" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="0">
                                <Grid Padding="10"
                                      ColumnDefinitions="{OnIdiom Phone='180,120,140', Desktop='3*,2*,2*'}"
                                      BackgroundColor="{StaticResource SurfaceSecondary}">
                                    <Label x:Name="HeaderCol1" Text="ACTIVIDAD" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Label x:Name="HeaderCol2" Grid.Column="1" Text="TARIFA" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Label x:Name="HeaderCol3" Grid.Column="2" Text="TOTAL" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                </Grid>

                                <CollectionView x:Name="ReportList" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout Padding="40" HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="Sin datos" 
                                                   FontSize="16" 
                                                   FontAttributes="Bold" 
                                                   TextColor="{StaticResource TextSecondary}" 
                                                   HorizontalOptions="Center" />
                                            <Label Text="No hay registros en el período seleccionado" 
                                                   FontSize="12" 
                                                   TextColor="{StaticResource TextTertiary}" 
                                                   HorizontalOptions="Center" 
                                                   Margin="0,8,0,0" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Border}" StrokeThickness="1" Padding="10,8">
                                                <Grid ColumnDefinitions="{OnIdiom Phone='180,120,140', Desktop='3*,2*,2*'}" ColumnSpacing="8">
                                                    <Label Text="{Binding Col1}" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                    <Label Grid.Column="1" Text="{Binding Col2}" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                                    <VerticalStackLayout Grid.Column="2" Spacing="2">
                                                        <Label Text="{Binding Col3}" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        <Label Text="{Binding Col3Sub}" FontSize="10" TextColor="{StaticResource TextTertiary}" IsVisible="{Binding HasCol3Sub}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
