<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:frontend.Models"
             x:Class="frontend.Pages.ReportsPage"
             Title=""
             Padding="0">

    <Grid RowDefinitions="*" ColumnDefinitions="*" Background="{StaticResource AppBackgroundBrush}">
        <ScrollView>
            <VerticalStackLayout Padding="{OnIdiom Phone=12, Desktop=20}" Spacing="{OnIdiom Phone=12, Desktop=16}">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12"
                    VerticalOptions="Center"
                    Padding="0">

                    <!-- Text -->
                    <VerticalStackLayout Spacing="2"
                                        VerticalOptions="Center"
                                        Grid.Column="0">

                        <Label Text="Reportes"
                            FontSize="{OnIdiom Phone=18, Desktop=20}"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label x:Name="ReportPeriodLabel"
                            FontSize="{OnIdiom Phone=10, Desktop=11}"
                            TextColor="{StaticResource TextSecondary}"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Button -->
                    <Button Grid.Column="1"
                            Text="Descargar"
                            Clicked="OnDownloadClicked"
                            BackgroundColor="#9EC9B4"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnIdiom Phone=11, Desktop=12}"
                            HeightRequest="{OnIdiom Phone=36, Desktop=40}"
                            Padding="{OnIdiom Phone='12,0', Desktop='16,0'}"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                </Grid>

                    <Grid ColumnDefinitions="{OnIdiom Phone='*,*', Desktop='*,*'}"
                        RowDefinitions="Auto"
                        ColumnSpacing="{OnIdiom Phone=8, Desktop=12}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Desde" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker x:Name="StartDatePicker"
                                        TextColor="{StaticResource TextPrimary}"
                                        DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                    </Border>
                        <Border Grid.Column="1"
                            Style="{StaticResource CardFrame}" Padding="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Hasta" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker x:Name="EndDatePicker"
                                        TextColor="{StaticResource TextPrimary}"
                                        DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                    <Grid ColumnDefinitions="{OnIdiom Phone='*,*', Desktop='*,*'}"
                        RowDefinitions="Auto"
                        ColumnSpacing="{OnIdiom Phone=8, Desktop=12}">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalHoursLabel" Text="0.0h" FontSize="{OnIdiom Phone=18, Desktop=24}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Horas Totales" FontSize="{OnIdiom Phone=10, Desktop=11}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                        <Border Grid.Column="1"
                            Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="TotalAmountLabel" Text="B/.0.00" FontSize="{OnIdiom Phone=18, Desktop=24}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Monto Total" FontSize="{OnIdiom Phone=10, Desktop=11}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tabla Resumen -->
                <Border Stroke="Transparent"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="0">

                        <!-- Header verde -->
                        <Grid BackgroundColor="#9EC9B4" Padding="16,12">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="ReportTitleLabel"
                                    Text="Resumen"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="White" />
                                <Label x:Name="ReportSubtitleLabel"
                                    Text="Totales agrupados por actividad"
                                    FontSize="11"
                                    TextColor="#E8F5EE" />
                            </VerticalStackLayout>
                        </Grid>

                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">

                            <VerticalStackLayout Spacing="0">

                                <!-- Header columnas -->
                                <Grid Padding="16,10"
                                    ColumnDefinitions="{OnIdiom Phone='150,90,90,100', Desktop='3*,1.6*,1.6*,1.8*'}"
                                    ColumnSpacing="6"
                                    BackgroundColor="#FAFAF7">

                                    <Label x:Name="HeaderCol1"
                                        Text="ACTIVIDAD"
                                        FontSize="10"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextSecondary}" />

                                    <Label x:Name="HeaderCol2"
                                        Grid.Column="1"
                                        Text="TARIFA"
                                        FontSize="10"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextSecondary}" />

                                    <Label x:Name="HeaderCol3"
                                        Grid.Column="2"
                                        Text="HORAS"
                                        FontSize="10"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextSecondary}" />

                                    <Label x:Name="HeaderCol4"
                                        Grid.Column="3"
                                        Text="MONTO"
                                        FontSize="10"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextSecondary}" />
                                </Grid>

                                <!-- Filas -->
                                <CollectionView x:Name="ReportList"
                                                SelectionMode="None">

                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout Padding="40"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center">
                                            <Label Text="Sin datos"
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource TextSecondary}"
                                                HorizontalOptions="Center" />
                                            <Label Text="No hay registros en el período seleccionado"
                                                FontSize="12"
                                                TextColor="{StaticResource TextTertiary}"
                                                HorizontalOptions="Center"
                                                Margin="0,8,0,0" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ReportRow">
                                                <Border Stroke="#EEEBE5"
                                                    StrokeThickness="1"
                                                    Padding="16,10"
                                                    BackgroundColor="White">

                                                <Grid ColumnDefinitions="{OnIdiom Phone='150,90,90,100', Desktop='3*,1.6*,1.6*,1.8*'}"
                                                    ColumnSpacing="6">

                                                    <!-- ACTIVIDAD -->
                                                    <Label Text="{Binding Col1}"
                                                        FontAttributes="Bold"
                                                        FontSize="11"
                                                        TextColor="{StaticResource TextPrimary}"
                                                        VerticalOptions="Center"
                                                        LineBreakMode="TailTruncation" />

                                                    <!-- TARIFA -->
                                                    <Label Grid.Column="1"
                                                        Text="{Binding Col2}"
                                                        FontSize="11"
                                                        TextColor="{StaticResource TextSecondary}"
                                                        VerticalOptions="Center" />

                                                    <!-- HORAS -->
                                                    <Label Grid.Column="2"
                                                        Text="{Binding Col3}"
                                                        FontAttributes="Bold"
                                                        FontSize="11"
                                                        TextColor="{StaticResource TextPrimary}"
                                                        VerticalOptions="Center" />

                                                    <!-- MONTO -->
                                                    <VerticalStackLayout Grid.Column="3"
                                                                        Spacing="2"
                                                                        VerticalOptions="Center">
                                                        <Label Text="{Binding Col4}"
                                                            FontAttributes="Bold"
                                                            FontSize="11"
                                                            TextColor="{StaticResource TextPrimary}" />

                                                        <Label Text="{Binding Col3Sub}"
                                                            FontSize="10"
                                                            TextColor="{StaticResource TextTertiary}"
                                                            IsVisible="{Binding HasCol3Sub}" />
                                                    </VerticalStackLayout>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </VerticalStackLayout>

                        </ScrollView>

                    </VerticalStackLayout>

                </Border>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
