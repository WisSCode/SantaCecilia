<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:frontend.Pages"
             x:Class="frontend.Pages.EditUserPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Fill" Padding="{OnIdiom Phone=12, Desktop=20}">
        <Border HorizontalOptions="Fill"
                MaximumWidthRequest="440"
                Stroke="#D6DAD7"
                StrokeThickness="1"
                BackgroundColor="White">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- ENCABEZADO -->
                <Grid BackgroundColor="#9EC9B4" Padding="{OnIdiom Phone=14, Desktop=20}" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="{OnIdiom Phone=2, Desktop=4}">
                        <Label Text="Editar Usuario"
                               FontSize="{OnIdiom Phone=15, Desktop=16}"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="SubtitleLabel"
                               Text="Asigne un trabajador al usuario"
                               FontSize="{OnIdiom Phone=10, Desktop=11}"
                               TextColor="#F2F7F4" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="X"
                            FontSize="{OnIdiom Phone=14, Desktop=16}"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Padding="4"
                            VerticalOptions="Start"
                            Clicked="OnCancelClicked" />
                </Grid>

                <!-- FORMULARIO -->
                <VerticalStackLayout Padding="{OnIdiom Phone=14, Desktop=24}" Spacing="{OnIdiom Phone=12, Desktop=16}">

                    <!-- EMAIL (solo lectura) -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Correo del usuario"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />
                        <Border Stroke="#D6DAD7" StrokeThickness="1" Padding="10,0"
                                BackgroundColor="#F6F5F0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <Label x:Name="EmailLabel"
                                FontSize="{OnIdiom Phone=12, Desktop=13}"
                                   TextColor="#6b7f78"
                                   VerticalOptions="Center"
                                   HeightRequest="30" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- TRABAJADOR ASIGNADO -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Trabajador asignado"
                               FontSize="{OnIdiom Phone=11, Desktop=12}"
                               FontAttributes="Bold"
                               TextColor="#2E3A34" />

                        <!-- Lista de trabajadores disponibles -->
                        <Border Stroke="#D6DAD7" StrokeThickness="1" BackgroundColor="White"
                                HeightRequest="{OnIdiom Phone=160, Desktop=180}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <CollectionView x:Name="WorkersListView"
                                            SelectionMode="Single"
                                            SelectionChanged="OnWorkerSelected">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:WorkerDisplayItem">
                                        <Border Padding="12,10"
                                            StrokeThickness="1"
                                                Stroke="#EEEBE5"
                                                BackgroundColor="{Binding BackgroundColor}">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding FullName}"
                                                           FontSize="{OnIdiom Phone=12, Desktop=13}"
                                                           FontAttributes="Bold"
                                                           TextColor="#2E3A34" />
                                                    <Label Text="{Binding Identification}"
                                                           FontSize="{OnIdiom Phone=10, Desktop=11}"
                                                           TextColor="#6b7f78" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1"
                                                       Text="?"
                                                          FontSize="{OnIdiom Phone=14, Desktop=16}"
                                                       FontAttributes="Bold"
                                                       TextColor="#9EC9B4"
                                                       IsVisible="{Binding IsSelected}"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>

                        <Label x:Name="NoWorkersLabel"
                               Text="No hay trabajadores disponibles sin usuario asignado."
                               FontSize="{OnIdiom Phone=10, Desktop=11}"
                               TextColor="#E07A5F"
                               IsVisible="False" />
                    </VerticalStackLayout>

                    <!-- BOTONES -->
                        <Grid ColumnDefinitions="{OnIdiom Phone='*', Desktop='*,*'}"
                          RowDefinitions="{OnIdiom Phone='Auto,Auto', Desktop='Auto'}"
                          ColumnSpacing="12"
                          RowSpacing="{OnIdiom Phone=10, Desktop=0}"
                          Margin="0,8,0,0">
                        <Button Grid.Column="0"
                                Text="Cancelar"
                            HeightRequest="{OnIdiom Phone=42, Desktop=44}"
                                BackgroundColor="Transparent"
                                TextColor="#2E3A34"
                                FontAttributes="Bold"
                                BorderColor="#D6DAD7"
                                BorderWidth="1"
                                Clicked="OnCancelClicked" />
                        <Button x:Name="SaveButton"
                            Grid.Column="{OnIdiom Phone=0, Desktop=1}"
                            Grid.Row="{OnIdiom Phone=1, Desktop=0}"
                                Text="Guardar Cambios"
                            HeightRequest="{OnIdiom Phone=42, Desktop=44}"
                                BackgroundColor="#9EC9B4"
                                TextColor="White"
                                FontAttributes="Bold"
                                IsEnabled="False"
                                Clicked="OnSaveClicked" />
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
