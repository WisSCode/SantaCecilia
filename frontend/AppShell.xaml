<?xml version="1.0" encoding="utf-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:frontend.Pages"
    x:Class="frontend.AppShell"
    Title="Santa Cecilia"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="White"
    FlyoutWidth="240"
    Shell.NavBarIsVisible="True">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid x:Name="ItemRoot" Padding="14,10">
                <Label x:Name="ItemTitle" Text="{Binding Title}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup Name="CommonStates">
                        <VisualState Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="16,20,16,16" BackgroundColor="White" Spacing="8">
            <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                <Border BackgroundColor="{StaticResource AccentBlue}" WidthRequest="36" HeightRequest="36">
                    <Label Text="SC" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource BrandSkyBlueDark}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Santa Cecilia" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Gestión de Nómina" FontSize="10" TextColor="{StaticResource TextTertiary}" />
                </VerticalStackLayout>
            </Grid>
            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Border}" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto" BackgroundColor="White">
            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Border}" />
            <VerticalStackLayout Grid.Row="1" Spacing="2" Margin="0,12,0,10">
                <Label Text="Próximo pago" FontSize="10" TextColor="{StaticResource TextTertiary}" />
                <Label x:Name="NextPaymentLabel" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            </VerticalStackLayout>
            <Grid Grid.Row="2" ColumnDefinitions="32,*" ColumnSpacing="8">
                <Border BackgroundColor="{StaticResource BrandSkyBlue}" WidthRequest="28" HeightRequest="28">
                    <Label Text="A" FontAttributes="Bold" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Grid.Column="1" Text="Administrador" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
            </Grid>
            <Button Grid.Row="3"
                    Text="Cerrar sesión"
                    Style="{StaticResource OutlineButton}"
                    FontSize="12"
                    Padding="12,8"
                    Margin="0,12,0,0"
                    Clicked="OnLogoutClicked" />
        </Grid>
    </Shell.FlyoutFooter>

    <!-- Worker Menu -->
    <FlyoutItem x:Name="WorkerHomeItem" Title="Mi Portal" Route="workershome" IsVisible="False">
        <ShellContent Route="workershomeContent" ContentTemplate="{DataTemplate pages:WorkersHomePage}" />
    </FlyoutItem>

    <!-- Admin Menu -->
    <FlyoutItem x:Name="DashboardItem" Title="Inicio" Route="dashboard">
        <ShellContent Route="dashboardContent" ContentTemplate="{DataTemplate pages:DashboardPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="TimeTrackingItem" Title="Registro Diario" Route="timetracking">
        <ShellContent Route="timetrackingContent" ContentTemplate="{DataTemplate pages:TimeTrackingPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="WorkersItem" Title="Trabajadores" Route="workers">
        <ShellContent Route="workersContent" ContentTemplate="{DataTemplate pages:WorkersPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="PayrollItem" Title="Nómina" Route="payroll">
        <ShellContent Route="payrollContent" ContentTemplate="{DataTemplate pages:PayrollPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="ReportsItem" Title="Reportes" Route="reports">
        <ShellContent Route="reportsContent" ContentTemplate="{DataTemplate pages:ReportsPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="BatchesItem" Title="Lotes" Route="batches">
        <ShellContent Route="batchesContent" ContentTemplate="{DataTemplate pages:BatchesPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="WorkTypesItem" Title="Tipos de Trabajo" Route="worktypes">
        <ShellContent Route="worktypesContent" ContentTemplate="{DataTemplate pages:WorkTypesPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="UsersItem" Title="Usuarios" Route="users">
        <ShellContent Route="usersContent" ContentTemplate="{DataTemplate pages:UsersPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Logs" Route="logs">
        <ShellContent Route="logsContent" ContentTemplate="{DataTemplate pages:LogsPage}" />
    </FlyoutItem>

</Shell>